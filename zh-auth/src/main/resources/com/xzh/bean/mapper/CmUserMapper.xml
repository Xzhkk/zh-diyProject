        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xzh.bean.mapper.CmUserMapper">

    <resultMap id="BaseResultMap" type="com.xzh.bean.CmUser">
            <id property="id" column="id" />
